# PostgreSQL aplikasi BRI Tool
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/bri_tool
# Koneksi langsung khusus migrasi, pg_dump, dan administrasi. Di Supabase gunakan port 5432.
DIRECT_DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/bri_tool

# Penyimpanan file. Gunakan `local` agar seluruh file tetap di komputer/server sendiri.
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./data/uploads

# Opsional untuk deployment yang memang menggunakan Supabase Storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=britoel-private

# Sumber SQLite lama, hanya digunakan satu kali oleh `npm run db:migrate-sqlite`
SQLITE_SOURCE_PATH=./data/britoel.db
BRIMEN_DB_PATH=../DATA BRIMEN/data/brimen.db

# Better Auth
BETTER_AUTH_URL=http://127.0.0.1:3000
BETTER_AUTH_SECRET=ganti-dengan-secret-random-minimal-32-karakter
BETTER_AUTH_ALLOW_SIGNUP=false

# Akun admin awal untuk `npm run db:seed`
SEED_ADMIN_NAME=Administrator BRIToel
SEED_ADMIN_EMAIL=admin@britoel.local
SEED_ADMIN_USERNAME=8014-SUPERADMIN
SEED_ADMIN_PASSWORD=ganti-kata-sandi-awal

# WhatsApp Cloud API (opsional; tanpa konfigurasi ini berjalan dalam mode simulasi)
WHATSAPP_SEND_MODE=simulation
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_TEMPLATE_PIPELINE=penawaran_suplesi
WHATSAPP_TEMPLATE_REMINDER=pengingat_setoran
WHATSAPP_TEMPLATE_LANGUAGE=id
